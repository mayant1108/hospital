# Backend .env template - copy to .env and fill values

MONGO_URI=mongodb://localhost:27017/hospital_management
# or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/hospital?retryWrites=true&w=majority

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars

PORT=5001

# Optional
NODE_ENV=development

